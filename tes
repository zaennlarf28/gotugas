    function confirmDeleteSiswa(url, nama) {
        Swal.fire({
            title: 'Hapus Siswa?',
            text: 'Yakin ingin menghapus siswa ' + nama + '?',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
